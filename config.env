# Ephemeral Splunk Configuration
# Non-sensitive defaults for deployment

# Deployment Configuration
AWS_REGION=us-east-1
DEPLOYMENT_ENVIRONMENT=prd
TAG_OWNER="Platform Team"

# Splunk Installer Configuration
SPLUNK_S3_INSTALLER_PARAM=/splunk-s3-installer/installer-url

# Instance Configuration  
# EC2_INSTANCE_TYPE=t3.medium
EC2_INSTANCE_TYPE=m5.xlarge

EBS_VOLUME_SIZE=50
AMI_OS=amazon-linux

# Spot Instance Configuration (60-70% cost savings)
# Set to true to use spot instances with capacity-optimized strategy
USE_SPOT_INSTANCES=true

# Network Configuration
USE_DEFAULT_VPC=true
ENABLE_SSM_ACCESS=true

# Monitoring Configuration
COST_ALARM_EMAIL=abbotnh@yahoo.com
COST_THRESHOLDS="5,10,20"
